{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "paths": {
      "@aico/blueprint": ["./blueprint/src", "../../blueprint/src"],
      "@aico/blueprint/*": ["./blueprint/src/*", "../../blueprint/src/*"],
      "@aico/model-catalog": ["../../backend/model-catalog/src"],
      "@aico/model-catalog/*": ["../../backend/model-catalog/src/*"],
      "@aico/entity-schema": ["../../backend/entity-schema/src"],
      "@aico/entity-schema/*": ["../../backend/entity-schema/src/*"],
      "@aico/flow-schema": ["../../backend/flow-schema/src"],
      "@aico/flow-schema/*": ["../../backend/flow-schema/src/*"],
      "@typescript-eslint/types": ["./src/types/typescript-eslint.d.ts"]
    },
    "types": ["svelte", "vite/client", "node"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    /**
     * Typecheck JS in `.svelte` and `.js` files by default.
     * Disable checkJs if you'd like to use dynamic types in JS.
     * Note that setting allowJs false does not prevent the use
     * of JS in `.svelte` files.
     */
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.d.ts",
    "../../blueprint/src/**/*.ts",
    "../../blueprint/src/**/*.svelte",
    "../../backend/model-catalog/src/**/*.ts",
    "../../backend/entity-schema/src/**/*.ts",
    "../../backend/flow-schema/src/**/*.ts",
    "./blueprint/src/**/*.ts",
    "./blueprint/src/**/*.svelte"
  ]
}
