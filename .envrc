# Shady local development environment

# Load local secrets synced from Doppler.
dotenv_if_exists .env.dev

export DOPPLER_PROJECT="shady"
export DOPPLER_CONFIG="dev"
export SHADY_ROOT=$(pwd)

PATH_add scripts

alias secrets-view='doppler secrets --project shady --config dev'
alias secrets-set='doppler secrets set --project shady --config dev'
alias secrets-sync='doppler secrets download --project shady --config dev --format env --no-file > .env.dev'

echo "Shady environment loaded. Root: $SHADY_ROOT"

if command -v doppler &> /dev/null; then
  if ! doppler whoami &>/dev/null 2>&1; then
    echo "Doppler: Not authenticated. Run 'doppler login' to authenticate."
  fi
else
  echo "Tip: Install Doppler CLI and run ./scripts/setup_doppler.sh"
fi
